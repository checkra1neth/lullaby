# Lullaby personalized — environment variables (design §8)
# Copy this file to .env.local and fill in each value.
# Never commit .env.local. See .gitignore.

# Public app URL (used as base for redirects and email links)
NEXT_PUBLIC_APP_URL=

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET_LULLABIES=

# Stripe (TEST MODE ONLY — STRIPE_SECRET_KEY must start with sk_test_, Req 4.6)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ONE_OFF=
STRIPE_PRICE_SUBSCRIPTION=

# OpenAI (lyrics generation, Req 8)
OPENAI_API_KEY=

# ElevenLabs
ELEVENLABS_API_KEY=
# JSON array of 2–3 preset voice ids, e.g. ["voice_id_a","voice_id_b"]
ELEVENLABS_VOICE_IDS=

# Inngest
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Upstash Redis (rate limiting, Req 3.7, 15.6)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Resend (delivery email, Req 14)
RESEND_API_KEY=
# e.g. "Lullaby <hello@lullaby.demo>"
RESEND_FROM=
